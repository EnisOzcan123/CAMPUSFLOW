<% if notice.present? %>
  <div class="alert alert-success rounded-3 border-0 shadow-sm">
    <%= notice %>
  </div>
<% end %>

<div class="page-header places-hero mb-4">
  <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
    <div>
      <p class="section-kicker mb-2">Kampüs keşfi</p>
      <h1 class="display-5 fw-bold mb-3">Bugün nerede çalışsak?</h1>
      <p class="lead text-muted mb-0">
        Sessiz köşeleri, güçlü WiFi noktalarını ve kampüste vakit geçirmeye değer alanları tek yerden keşfet.
      </p>
    </div>

    <% if admin_signed_in? %>
      <%= link_to new_place_path, class: "btn btn-dark rounded-pill px-4 header-action" do %>
        <i class="bi bi-plus-lg me-2"></i>
        Yeni mekan
      <% end %>
    <% end %>
  </div>

  <div class="places-hero-stats">
    <div>
      <span>Toplam mekan</span>
      <strong><%= @total_places %></strong>
    </div>

    <div>
      <span>Ortalama WiFi</span>
      <strong><%= @average_wifi_score %>/10</strong>
    </div>

    <div>
      <span>Ortalama sessizlik</span>
      <strong><%= @average_quiet_score %>/10</strong>
    </div>

    <div>
      <span>En sessiz</span>
      <strong class="metric-name"><%= @quietest_place&.name || "Henüz yok" %></strong>
    </div>
  </div>
</div>

<div class="filter-panel mb-4">
  <%= form_with url: places_path, method: :get, class: "row g-3 align-items-end" do |form| %>
    <div class="col-12 col-lg-5">
      <%= form.label :query, "Ara", class: "form-label fw-semibold" %>
      <%= form.search_field :query, value: params[:query], class: "form-control", placeholder: "Kütüphane, kafe, çalışma alanı ya da açıklama ara" %>
    </div>

    <div class="col-12 col-lg-4">
      <%= form.label :category, "Kategori", class: "form-label fw-semibold" %>
      <%= form.select :category,
          options_for_select(@categories, params[:category]),
          { include_blank: "Tüm kategoriler" },
          class: "form-select" %>
    </div>

    <div class="col-12 col-lg-3 d-flex gap-2">
      <%= form.submit "Uygula", class: "btn btn-dark rounded-pill flex-fill" %>
      <%= link_to "Temizle", places_path, class: "btn btn-outline-dark rounded-pill flex-fill" %>
    </div>
  <% end %>
</div>

<% if @upcoming_events.any? %>
  <div class="section-heading">
    <div>
      <p class="section-kicker mb-1">Kampüste neler var?</p>
      <h2 class="h4 fw-bold mb-0">Yaklaşan etkinlikler</h2>
    </div>
    <%= link_to "Etkinlikleri incele", events_path, class: "btn btn-outline-dark rounded-pill" %>
  </div>

  <div class="row g-3 mb-4">
    <% @upcoming_events.each do |event| %>
      <div class="col-12 col-lg-4">
        <%= link_to event_path(event), class: "event-strip" do %>
          <span><%= event.event_type %></span>
          <strong><%= event.title %></strong>
          <small><%= l(event.starts_at, format: :short) %> · <%= event.location %></small>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

<div class="section-heading">
  <div>
    <p class="section-kicker mb-1">Mekan rehberi</p>
    <h2 class="h4 fw-bold mb-0">Kampüs mekanları</h2>
  </div>
  <%= link_to "Haritada gör", campus_map_path, class: "btn btn-outline-dark rounded-pill" %>
</div>

<% if @places.any? %>
  <div class="row g-4">
    <% @places.each do |place| %>
      <div class="col-12 col-md-6 col-lg-4">
        <div class="card place-card h-100 border-0">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
              <span class="category-pill rounded-pill px-3 py-2">
                <%= place.category %>
              </span>
            </div>

            <h2 class="h4 fw-bold mb-2">
              <%= place.name %>
            </h2>

            <p class="place-card-copy">
              <%= truncate(place.description, length: 120) %>
            </p>

            <div class="score-stack mb-4">
              <div>
                <div class="d-flex justify-content-between small fw-semibold mb-1">
                  <span>WiFi</span>
                  <span><%= place.wifi_score %>/10</span>
                </div>
                <div class="progress score-progress" role="progressbar" aria-label="WiFi puanı" aria-valuenow="<%= place.wifi_score %>" aria-valuemin="0" aria-valuemax="10">
                  <div class="progress-bar" style="width: <%= place.wifi_score.to_i * 10 %>%"></div>
                </div>
              </div>

              <div>
                <div class="d-flex justify-content-between small fw-semibold mb-1">
                  <span>Sessizlik</span>
                  <span><%= place.quiet_score %>/10</span>
                </div>
                <div class="progress score-progress" role="progressbar" aria-label="Sessizlik puanı" aria-valuenow="<%= place.quiet_score %>" aria-valuemin="0" aria-valuemax="10">
                  <div class="progress-bar" style="width: <%= place.quiet_score.to_i * 10 %>%"></div>
                </div>
              </div>
            </div>

            <%= link_to place_path(place), class: "btn btn-outline-dark rounded-pill w-100 stretched-link-safe" do %>
              İncele
              <i class="bi bi-arrow-right ms-2"></i>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="bg-white border rounded-3 p-5 text-center shadow-sm">
    <h2 class="h4 fw-bold">Şimdilik rehberde mekan yok</h2>
    <p class="text-muted mb-4">İlk kampüs noktası eklendiğinde burada görünecek.</p>
    <% if admin_signed_in? %>
      <%= link_to "İlk mekanı ekle", new_place_path, class: "btn btn-dark rounded-pill px-4" %>
    <% end %>
  </div>
<% end %>
